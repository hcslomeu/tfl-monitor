# tfl-monitor — web env example
#
# Copy to `web/.env.local` for local development. Anything prefixed
# `NEXT_PUBLIC_*` is inlined into the client bundle at build time.

# Base URL for the FastAPI backend. Falls back to `http://localhost:8000`
# when unset. On Vercel this is set to the production hostname for both
# preview and production targets.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Opt-in offline mode. Set to `"true"` to render the dashboard from
# in-repo fixtures (`web/lib/mocks/*`) without hitting the backend.
# Any other value — including `"false"`, the empty string, or leaving
# the variable unset — keeps the live-data path. Vercel deploys leave
# this UNSET.
# NEXT_PUBLIC_USE_MOCKS=true
